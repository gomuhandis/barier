# ============================================================================
#  Shlakbaum — environment template
#
#  All keys below are REQUIRED. There are no hardcoded defaults in the app —
#  Pydantic validation will refuse to start the server if any key is missing.
#  Copy this file to `.env` and fill in real values.
# ============================================================================

# ---------------- App ----------------
APP_NAME=Shlakbaum
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
# How the cameras and telegram users reach this server.
PUBLIC_LISTENER_URL=http://192.168.1.50:8000

# ---------------- Admin /login form ----------------
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ---------------- JWT bearer (every API request) ----------------
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# ---------------- API docs ----------------
# Set to false in production to hide /docs, /redoc, /openapi.json.
ENABLE_DOCS=true

# ---------------- ANPR camera push (/isapi/anpr/{role}) ----------------
# Cameras can't carry a JWT, so this endpoint is authenticated separately.
# A request is accepted when ANY of the following matches:
#   1. Source IP equals one of the configured CAM*_HOST values.
#   2. Header `X-ANPR-Secret` equals ANPR_INGEST_SECRET (when set).
#   3. HTTP Basic auth equals ANPR_INGEST_USERNAME / _PASSWORD (when set).
# Leave the values blank to disable the corresponding path.
# On Hikvision pick **Basic** auth (Digest is harder to validate).
ANPR_INGEST_SECRET=
ANPR_INGEST_USERNAME=
ANPR_INGEST_PASSWORD=

# ---------------- PostgreSQL ----------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shlakbaum

# ---------------- Camera 1 (ENTRY — outside) ----------------
CAM1_NAME=Entry
CAM1_ROLE=entry
CAM1_HOST=192.168.1.64
CAM1_PORT=80
CAM1_CHANNEL=1
CAM1_USERNAME=admin
CAM1_PASSWORD=admin12345
CAM1_USE_HTTPS=false

# ---------------- Camera 2 (EXIT — inside) ----------------
CAM2_NAME=Exit
CAM2_ROLE=exit
CAM2_HOST=192.168.1.65
CAM2_PORT=80
CAM2_CHANNEL=1
CAM2_USERNAME=admin
CAM2_PASSWORD=admin12345
CAM2_USE_HTTPS=false

# ---------------- Telegram ----------------
TELEGRAM_BOT_TOKEN=0000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------- Alternating-close scheduler ----------------
# Seconds between alternating keep-close pings to each camera. Min 1.
ALT_CLOSE_INTERVAL_SECONDS=5
